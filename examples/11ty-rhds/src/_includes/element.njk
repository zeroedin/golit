{% extends "base.njk" %}

{% block imports %}
  {% for name in imports %}
  <link rel="stylesheet" href="/rhds/css/{{ name }}-lightdom.css">
  {% endfor %}
  <script type="module">
    import '@lit-labs/ssr-client/lit-element-hydrate-support.js';
    {% for name in imports %}
    import '@rhds/elements/{{ name }}/{{ name }}.js';
    {% endfor %}
  </script>
{% endblock %}

{% block main %}
<h1>{{ title }}</h1>
{{ content | safe }}
{% endblock %}
